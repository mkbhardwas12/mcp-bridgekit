MCP_BRIDGEKIT_REDIS_URL=redis://localhost:6379
MCP_BRIDGEKIT_MAX_SESSIONS=100
MCP_BRIDGEKIT_SESSION_TTL_SECONDS=3600
MCP_BRIDGEKIT_TIMEOUT_THRESHOLD_SECONDS=25.0
MCP_BRIDGEKIT_JOB_RESULT_TTL_SECONDS=600
MCP_BRIDGEKIT_DEFAULT_MCP_COMMAND=python
MCP_BRIDGEKIT_DEFAULT_MCP_ARGS=["examples/mcp_server.py"]

# v0.8.0 — Auth (leave empty to disable; set to a strong random string to enable)
MCP_BRIDGEKIT_API_KEY=

# v0.8.0 — Rate limiting per user per minute (0 = disabled)
MCP_BRIDGEKIT_RATE_LIMIT_PER_MINUTE=60

# v0.8.0 — Retry transient tool-call failures (0 = no retry)
MCP_BRIDGEKIT_MAX_TOOL_RETRIES=2

# v0.9.0 — Push notifications (webhook + SSE)
# Webhook: POST job completion payload to your AWS API / backend (leave empty to disable)
# MCP_BRIDGEKIT_WEBHOOK_URL=https://your-api.example.com/webhook/mcp
# SSE: broadcast completion via GET /mcp/events/{job_id} (true by default)
MCP_BRIDGEKIT_ENABLE_SSE=true
